<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <LinearLayout
    android:id="@+id/dialog_panel"
    android:layout_width="@dimen/tv_dialog_width"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom|center_horizontal"
    android:background="@drawable/tv_dialog_panel_background"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="20dp"
    android:paddingEnd="24dp"
    android:paddingBottom="20dp">

    <View
      android:layout_width="44dp"
      android:layout_height="2dp"
      android:layout_gravity="center_horizontal"
      android:background="@color/button_bg_color" />

    <TextView
      android:id="@+id/dialog_title"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="14dp"
      android:ellipsize="end"
      android:maxLines="2"
      android:textColor="@android:color/white"
      android:textSize="20sp"
      tools:text="Plainsong - The Cure" />

    <ScrollView
      android:id="@+id/dialog_message_scroll"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="12dp"
      android:background="@drawable/tv_dialog_action_background"
      android:fadeScrollbars="true"
      android:focusable="true"
      android:focusableInTouchMode="true"
      android:paddingStart="14dp"
      android:paddingTop="10dp"
      android:paddingEnd="14dp"
      android:paddingBottom="10dp"
      android:scrollbars="none"
      android:visibility="gone">

      <TextView
        android:id="@+id/dialog_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/text_light_faded"
        android:textSize="16sp"
        tools:text="Dialog message" />

    </ScrollView>

    <FrameLayout
      android:id="@+id/dialog_custom_content"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:visibility="gone" />

    <LinearLayout
      android:id="@+id/dialog_actions"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:orientation="vertical" />

  </LinearLayout>

</FrameLayout>
