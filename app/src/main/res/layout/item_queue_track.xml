<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:custom="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="vertical"
  android:clickable="true"
  android:focusable="true"
  android:clipChildren="false"
  android:clipToPadding="false">

  <ImageView
    android:id="@+id/reorder_up"
    android:layout_width="12dp"
    android:layout_height="8dp"
    android:layout_gravity="top|center_horizontal"
    android:src="@drawable/ic_queue_chevron_up"
    android:layout_marginBottom="4dp"
    android:visibility="gone" />

  <LinearLayout
    android:id="@+id/row_content"
    android:layout_width="match_parent"
    android:layout_height="58dp"
    android:layout_gravity="center_vertical"
    android:background="@drawable/queue_row_background"
    android:duplicateParentState="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="18dp"
    android:paddingEnd="18dp">

    <TextView
      android:id="@+id/index"
      android:layout_width="44dp"
      android:layout_height="wrap_content"
      android:duplicateParentState="true"
      android:maxLines="1"
      android:textColor="@color/text_light_selector"
      android:textSize="16sp"
      tools:text="07" />

    <es.claucookie.miniequalizerlibrary.EqualizerView
      android:id="@+id/playing"
      android:layout_width="18dp"
      android:layout_height="18dp"
      android:layout_marginEnd="18dp"
      custom:animDuration="4000"
      custom:foregroundColor="@color/button_bg_color" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:duplicateParentState="true"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_light_selector"
        android:textSize="18sp"
        tools:text="Plainsong" />

      <TextView
        android:id="@+id/artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:duplicateParentState="true"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_light_selector"
        android:textSize="14sp"
        tools:text="The Cure" />

    </LinearLayout>

    <TextView
      android:id="@+id/duration"
      android:layout_width="58dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="18dp"
      android:duplicateParentState="true"
      android:maxLines="1"
      android:textAlignment="viewEnd"
      android:textColor="@color/text_light_selector"
      android:textSize="15sp"
      tools:text="5:12" />

  </LinearLayout>

  <ImageView
    android:id="@+id/reorder_down"
    android:layout_width="12dp"
    android:layout_height="8dp"
    android:layout_gravity="bottom|center_horizontal"
    android:src="@drawable/ic_queue_chevron_down"
    android:layout_marginTop="4dp"
    android:visibility="gone" />

</LinearLayout>
